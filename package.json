{
	"scripts": {
		"start": "cd server && npm start",
		"postinstall": "cd server && npm install",
		"dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:admin\" \"npm run dev:judger\" \"npm run dev:ai\"",
		"dev:server": "cd server && npm run dev",
		"dev:client": "cd client && npm run dev",
		"dev:admin": "cd admin && npm run dev",
		"dev:judger": "cd judger && npm run dev",
		"dev:ai": "cd ai-service && python main.py"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"prettier": "^3.5.3",
		"prettier-plugin-tailwindcss": "^0.6.11"
	},
	"dependencies": {
		"axios": "^1.11.0",
		"cheerio": "^1.1.2",
		"mongoose": "^8.18.0",
		"simple-peer": "^9.11.1",
		"socket.io-client": "^4.8.2",
		"turndown": "^7.2.1"
	}
}
